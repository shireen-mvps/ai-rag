# Anthropic — https://console.anthropic.com
ANTHROPIC_API_KEY=your_anthropic_key_here

# Upstash Vector — https://console.upstash.com/vector
# Create a Dense index with a built-in embedding model (e.g. BAAI/bge-small-en-v1.5)
UPSTASH_VECTOR_REST_URL=your_upstash_vector_url_here
UPSTASH_VECTOR_REST_TOKEN=your_upstash_vector_token_here

# Upstash Redis — https://console.upstash.com/redis
# Used for rate limiting (3 uploads / 20 chat messages per IP per 24 hours)
# Create a separate Redis database — free tier is sufficient
UPSTASH_REDIS_REST_URL=your_upstash_redis_url_here
UPSTASH_REDIS_REST_TOKEN=your_upstash_redis_token_here

# Supabase — https://supabase.com (optional — enables Google auth + cross-device sync)
# Settings → API → Project URL and anon public key
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key_here
